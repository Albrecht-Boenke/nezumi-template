{
  "name": "@packages/ui",
  "version": "1.0.0",
  "private": true,
  "description": "Nezumi UI component library and design tokens for the Nezumi monorepo",
  "files": [
    "src",
    "src/styles"
  ],
  "scripts": {
    "dev": "tsc --noEmit --watch",
    "lint": "eslint src",
    "typecheck": "tsc --noEmit",
    "test": "vitest",
    "test:ui": "vitest --ui"
  },
  "imports": {
    "#components/*": "./src/components/*.tsx",
    "#lib/*": "./src/lib/*.ts"
  },
  "exports": {
    "./globals.css": "./src/styles/global.css",
    "./design-tokens.css": "./src/styles/design-tokens.css",
    "./components/button": "./src/components/button.tsx",
    "./components/container": "./src/components/container.tsx",
    "./components/grid": "./src/components/grid.tsx",
    "./components/flex": "./src/components/flex.tsx",
    "./components/box": "./src/components/box.tsx",
    "./components/section": "./src/components/section.tsx",
    "./components/typography": "./src/components/typography.tsx",
    "./components/input": "./src/components/input.tsx",
    "./components/card": "./src/components/card.tsx",
    "./components/toast": "./src/components/toast.tsx",
    "./layout": "./src/layout/index.ts",
    "./providers/theme": "./src/providers/Theme/index.tsx",
    "./lib/utils": "./src/lib/utils.ts",
    "./package.json": "./package.json"
  },
  "sideEffects": [
    "./src/styles/**/*.css"
  ],
  "peerDependencies": {
    "react": "^19.2.6",
    "react-dom": "^19.2.6",
    "tailwindcss": "^4.2.4"
  },
  "peerDependenciesMeta": {
    "tailwindcss": {
      "optional": true
    }
  },
  "dependencies": {
    "@radix-ui/react-slot": "^1.2.3",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "next-themes": "^0.4.6",
    "tailwind-merge": "^3.5.0"
  },
  "devDependencies": {
    "@types/node": "catalog:",
    "@types/react": "catalog:",
    "@types/react-dom": "catalog:",
    "jsdom": "^29.1.1",
    "react": "catalog:",
    "react-dom": "catalog:",
    "tailwindcss": "catalog:",
    "typescript": "catalog:",
    "vitest": "^4.1.5"
  }
}
